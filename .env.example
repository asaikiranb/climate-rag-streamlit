# Groq API Key
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_FALLBACK=your_secondary_groq_api_key_here

# Google Vision fallback OCR (API key is used for the REST fallback path)
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here
GOOGLE_VISION_CLIENT_ID=your_google_oauth_client_id_here

# ChromaDB Collection Name (local storage, no cloud credentials needed)
CHROMA_COLLECTION_NAME=saikiran_corpus

# Whisper model size for voice input feature.
# Use 'medium' locally (best quality for Indian languages, needs ~1.2GB RAM).
# Use 'small' on Streamlit Community Cloud free tier (fits within 1GB RAM limit).
WHISPER_MODEL=medium

# Production app observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Optional web-search provider for confidence-gated fallback
WEB_SEARCH_PROVIDER=tavily
WEB_SEARCH_ENDPOINT=
WEB_SEARCH_API_KEY=
WEB_SEARCH_ALLOWED_DOMAINS=

# Optional Contextual AI baseline adapter endpoint
CONTEXTUAL_API_KEY=
CONTEXTUAL_AGENT_ENDPOINT=
CONTEXTUAL_BASE_URL=https://api.contextual.ai/v1
CONTEXTUAL_AGENT_ID=

# Local translation runtime
# Final UI translation is only exposed for Indian languages.
ENABLE_LOCAL_TRANSLATION=true
LOCAL_TRANSLATION_MODEL=ai4bharat/indictrans2-en-indic-dist-200M
ENABLE_GOOGLE_TRANSLATE_FALLBACK=true
GOOGLE_TRANSLATE_TIMEOUT_SECONDS=15
